---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PageScrollbar from '../components/PageScrollbar.astro';
import Sidebar from '../components/Sidebar.astro';

type Heading = { depth: number; slug: string; text: string };
type PostNavTarget = { slug: string; shortTitle: string };
type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
	prevPost?: PostNavTarget;
	nextPost?: PostNavTarget;
};

const { title, description, pubDate, updatedDate, heroImage, headings, prevPost, nextPost } =
	Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			html {
				scroll-behavior: smooth;
				transition: scroll-behavior 3s ease;
			}
			body {
				padding-left: var(--sidebar-width);
				transition: padding-left 1s ease;
			}
			body.sidebar-collapsed {
				padding-left: 0;
			}
			@media (max-width: 720px) {
				body {
					padding-left: 0;
				}
			}
			.prose hr {
				border: none;
				border-top: 2px solid rgb(var(--gray-dark));
			}
			@media (prefers-color-scheme: dark) {
				.prose hr {
					border-top: 2px solid rgb(var(--gray-light));
				}
			}
		</style>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 3em 2em 1.5em;
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 1000px;
				max-width: 100%;
				margin: 0 auto;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.title hr {
				border: none;
				border-top: 2px solid rgb(var(--gray-dark));
			}
			@media (prefers-color-scheme: dark) {
				.prose {
					color: rgb(var(--gray-light));
				}
				.date {
					color: oklch(0.708 0 0);
				}
				.title hr {
					border-top: 2px solid rgb(var(--gray-light));
				}
			}
			.post-pagination {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				padding-top: 2.5em;
				width: 1000px;
				max-width: 100%;
				margin: 0 auto;
			}
			.pagination-btn {
				display: flex;
				flex-direction: row;
				align-items: stretch;
				gap: 0.5em;
				padding: 0.5em 1.25em;
				border-radius: calc(var(--radius) * 1.5);
				background: color-mix(in oklch, var(--input) 30%, transparent);
				color: color-mix(in oklch, var(--foreground) 75%, var(--background));
				text-decoration: none;
				font-size: 1rem;
				font-weight: 500;
				line-height: 1.33;
				transition:
					background 0.2s,
					color 0.2s;
				max-width: 18em;
			}
			.pagination-btn:hover {
				background: color-mix(in oklch, var(--input) 55%, transparent);
				color: color-mix(in oklch, var(--foreground) 75%, var(--background));
				text-decoration: none;
			}
			.pagination-chevron {
				display: flex;
				align-items: center;
				flex-shrink: 0;
			}
			.pagination-chevron svg {
				height: 100%;
				width: 2.5em;
				display: block;
				transition: transform 0.2s ease;
			}
			.pagination-prev:hover .pagination-chevron svg {
				transform: translateX(-3px);
			}
			.pagination-next:hover .pagination-chevron svg {
				transform: translateX(3px);
			}
			.pagination-text {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.pagination-label {
				font-style: italic;
			}
			.pagination-prev {
				padding-left: 0.2em;
			}
			.pagination-next {
				padding-right: 0.2em;
			}
		</style>
	</head>

	<body>
		<PageScrollbar />
		<Sidebar headings={headings} />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
			{
				(prevPost || nextPost) && (
					<nav class="post-pagination">
						<div>
							{prevPost && (
								<a
									href={`${base}blog/${prevPost.slug}`}
									class="pagination-btn pagination-prev"
								>
									<div class="pagination-chevron">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
									</div>
									<div class="pagination-text">
										<span class="pagination-label">Previous</span>
										<span>{prevPost.shortTitle}</span>
									</div>
								</a>
							)}
						</div>
						<div>
							{nextPost && (
								<a
									href={`${base}blog/${nextPost.slug}`}
									class="pagination-btn pagination-next"
								>
									<div class="pagination-text">
										<span class="pagination-label">Next</span>
										<span>{nextPost.shortTitle}</span>
									</div>
									<div class="pagination-chevron">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
									</div>
								</a>
							)}
						</div>
					</nav>
				)
			}
		</main>
		<Footer />
	</body>
</html>
