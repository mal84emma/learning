---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PageScrollbar from '../components/PageScrollbar.astro';
import Search from '../components/Search.astro';
import ShortcutsModal from '../components/ShortcutsModal.astro';
import Sidebar from '../components/Sidebar.astro';

type Heading = { depth: number; slug: string; text: string };
type PostNavTarget = { slug: string; shortTitle: string };
type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
	readingTime?: string;
	prevPost?: PostNavTarget;
	nextPost?: PostNavTarget;
};

const { title, description, pubDate, updatedDate, heroImage, headings, readingTime, prevPost, nextPost } =
	Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			html {
				scroll-behavior: smooth;
				transition: scroll-behavior 3s ease;
			}
			body {
				padding-left: var(--sidebar-width);
				transition: padding-left 1s ease;
			}
			body.sidebar-collapsed {
				padding-left: 0;
			}
			@media (max-width: 720px) {
				body {
					padding-left: 0;
				}
			}
			.prose hr {
				border: none;
				border-top: 2px solid rgb(var(--gray-dark));
			}
			@media (prefers-color-scheme: dark) {
				.prose hr {
					border-top: 2px solid rgb(var(--gray-light));
				}
			}
		</style>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 3em 2em 1.5em;
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 1000px;
				max-width: 100%;
				margin: 0 auto;
				color: rgb(var(--gray-dark));
				font-size: var(--prose-font-size);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.title hr {
				border: none;
				border-top: 2px solid rgb(var(--gray-dark));
			}
			@media (prefers-color-scheme: dark) {
				.prose {
					color: rgb(var(--gray-light));
				}
				.date {
					color: oklch(0.708 0 0);
				}
				.title hr {
					border-top: 2px solid rgb(var(--gray-light));
				}
			}
			.post-pagination {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				padding-top: 2.5em;
				width: 1000px;
				max-width: 100%;
				margin: 0 auto;
			}
			.pagination-btn {
				display: flex;
				flex-direction: row;
				align-items: stretch;
				gap: 0.5em;
				padding: 0.5em 1.25em;
				border-radius: calc(var(--radius) * 1.5);
				background: color-mix(in oklch, var(--input) 30%, transparent);
				color: color-mix(in oklch, var(--foreground) 75%, var(--background));
				text-decoration: none;
				font-size: 1rem;
				font-weight: 500;
				line-height: 1.33;
				transition:
					background 0.2s,
					color 0.2s;
				max-width: 18em;
			}
			.pagination-btn:hover {
				background: color-mix(in oklch, var(--input) 55%, transparent);
				color: color-mix(in oklch, var(--foreground) 75%, var(--background));
				text-decoration: none;
			}
			.pagination-chevron {
				display: flex;
				align-items: center;
				flex-shrink: 0;
			}
			.pagination-chevron svg {
				height: 100%;
				width: 2.5em;
				display: block;
				transition: transform 0.2s ease;
			}
			.pagination-prev:hover .pagination-chevron svg {
				transform: translateX(-3px);
			}
			.pagination-next:hover .pagination-chevron svg {
				transform: translateX(3px);
			}
			.pagination-text {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.pagination-label {
				font-style: italic;
			}
			.pagination-prev {
				padding-left: 0.2em;
			}
			.pagination-next {
				padding-right: 0.2em;
			}
			#continue-banner {
				position: fixed;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%) translateY(1rem);
				z-index: 200;
				display: flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.5em 0.75em 0.5em 1em;
				background: var(--background);
				border: 1px solid rgb(var(--gray-light));
				border-radius: calc(var(--radius) * 2);
				box-shadow: 0 2px 12px rgba(var(--black), 12%);
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.25s ease, transform 0.25s ease;
				white-space: nowrap;
			}
			#continue-banner.visible {
				opacity: 1;
				pointer-events: auto;
				transform: translateX(-50%) translateY(0);
			}
			#continue-jump {
				background: none;
				border: none;
				padding: 0;
				color: var(--accent);
				font-family: inherit;
				font-size: 0.9rem;
				font-weight: 500;
				cursor: pointer;
				transition: color 0.2s ease;
			}
			#continue-jump:hover {
				color: oklch(from var(--accent) calc(l - 0.1) c h);
			}
			#continue-dismiss {
				background: none;
				border: none;
				padding: 0 0.15em;
				color: rgb(var(--gray));
				font-size: 0.75rem;
				cursor: pointer;
				line-height: 1;
				transition: color 0.2s ease;
			}
			#continue-dismiss:hover {
				color: rgb(var(--gray-dark));
			}
			@media (prefers-color-scheme: dark) {
				#continue-banner {
					border-color: oklch(1 0 0 / 10%);
					box-shadow: 0 2px 12px rgba(0, 0, 0, 40%);
				}
				#continue-dismiss:hover {
					color: rgb(var(--gray-light));
				}
			}
			#scroll-top-btn {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				z-index: 150;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 2.25rem;
				height: 2.25rem;
				padding: 0;
				background: var(--background);
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius-md);
				color: rgb(var(--gray-dark));
				cursor: pointer;
				box-shadow: 0 1px 4px rgba(var(--black), 8%);
				opacity: 0;
				pointer-events: none;
				transform: translateY(0.5rem);
				transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
			}
			#scroll-top-btn.visible {
				opacity: 1;
				pointer-events: auto;
				transform: translateY(0);
			}
			#scroll-top-btn:hover {
				color: var(--accent);
			}
			@media (prefers-color-scheme: dark) {
				#scroll-top-btn {
					border-color: oklch(1 0 0 / 10%);
					color: rgb(var(--gray-light));
					box-shadow: 0 1px 4px rgba(0, 0, 0, 30%);
				}
			}
		</style>
	</head>

	<body>
		<PageScrollbar />
		<Sidebar headings={headings} />
		<Search />
		<ShortcutsModal />
		<div id="continue-banner" role="status" aria-live="polite">
			<button id="continue-jump" aria-label="Jump back to saved position">Jump back in ↓</button>
			<button id="continue-dismiss" aria-label="Dismiss">✕</button>
		</div>
		<div
			id="post-nav-data"
			hidden
			data-prev-slug={prevPost?.slug ?? ''}
			data-next-slug={nextPost?.slug ?? ''}
		></div>
		<button id="scroll-top-btn" aria-label="Scroll to top">
			<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="18 15 12 9 6 15" />
			</svg>
		</button>
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose" data-pagefind-body>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{readingTime && <span class="reading-time"> · {readingTime}</span>}
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
			{
				(prevPost || nextPost) && (
					<nav class="post-pagination" data-pagefind-ignore>
						<div>
							{prevPost && (
								<a
									href={`${base}/blog/${prevPost.slug}`}
									class="pagination-btn pagination-prev"
								>
									<div class="pagination-chevron">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
									</div>
									<div class="pagination-text">
										<span class="pagination-label">Previous</span>
										<span>{prevPost.shortTitle}</span>
									</div>
								</a>
							)}
						</div>
						<div>
							{nextPost && (
								<a
									href={`${base}/blog/${nextPost.slug}`}
									class="pagination-btn pagination-next"
								>
									<div class="pagination-text">
										<span class="pagination-label">Next</span>
										<span>{nextPost.shortTitle}</span>
									</div>
									<div class="pagination-chevron">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
									</div>
								</a>
							)}
						</div>
					</nav>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<script>
	const scrollTopBtn = document.getElementById('scroll-top-btn')!;
	let scrollTopVisible = false;

	window.addEventListener('scroll', () => {
		const shouldShow = window.scrollY > 400;
		if (shouldShow !== scrollTopVisible) {
			scrollTopVisible = shouldShow;
			scrollTopBtn.classList.toggle('visible', scrollTopVisible);
		}
	}, { passive: true });

	scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

<script>
	const banner = document.getElementById('continue-banner')!;
	const jumpBtn = document.getElementById('continue-jump')!;
	const dismissBtn = document.getElementById('continue-dismiss')!;
	const storageKey = `learning-scroll-${window.location.pathname}`;
	const dismissKey = `learning-scroll-dismissed-${window.location.pathname}`;

	let rafPending = false;
	window.addEventListener('scroll', () => {
		if (!rafPending) {
			rafPending = true;
			requestAnimationFrame(() => {
				localStorage.setItem(storageKey, String(window.scrollY));
				rafPending = false;
			});
		}
	}, { passive: true });

	function hideBanner() {
		banner.classList.remove('visible');
	}

	dismissBtn.addEventListener('click', () => {
		sessionStorage.setItem(dismissKey, 'true');
		hideBanner();
	});

	jumpBtn.addEventListener('click', () => {
		const saved = Number(localStorage.getItem(storageKey));
		window.scrollTo({ top: saved, behavior: 'smooth' });
		hideBanner();
	});

	window.addEventListener('scroll', hideBanner, { passive: true, once: true });

	const saved = Number(localStorage.getItem(storageKey));
	const dismissed = sessionStorage.getItem(dismissKey);
	if (saved > document.body.scrollHeight * 0.15 && !dismissed) {
		banner.classList.add('visible');
	}
</script>

<script>
	const navData = document.getElementById('post-nav-data')!;
	const base = import.meta.env.BASE_URL;
	const prevSlug = navData.dataset.prevSlug;
	const nextSlug = navData.dataset.nextSlug;

	function toggleSidebar() {
		const isCollapsed = document.getElementById('sidebar')!.classList.contains('collapsed');
		document.dispatchEvent(
			new CustomEvent('sidebar-set-collapsed', { detail: { collapsed: !isCollapsed } })
		);
	}

	function openSearch() {
		document.dispatchEvent(new CustomEvent('open-search'));
	}

	function openShortcuts() {
		document.dispatchEvent(new CustomEvent('open-shortcuts'));
	}

	document.addEventListener('keydown', (e) => {
		const el = document.activeElement as HTMLElement | null;
		if (el && ['INPUT', 'TEXTAREA', 'SELECT'].includes(el.tagName)) return;
		if (el?.isContentEditable) return;
		if (e.metaKey || e.ctrlKey || e.altKey) return;
		if ((e.key === 'ArrowRight' || e.key === ']') && nextSlug)
			location.href = `${base}/blog/${nextSlug}`;
		if ((e.key === 'ArrowLeft' || e.key === '[') && prevSlug)
			location.href = `${base}/blog/${prevSlug}`;
		if (e.key === 'f' || e.key === 's') toggleSidebar();
		if (e.key === '/') { e.preventDefault(); openSearch(); }
		if (e.key === '?') { e.preventDefault(); openShortcuts(); }
	});
</script>
