---
interface Props {
	front: string
	back: string
}
const { front, back } = Astro.props
---

<div
	class="flashcard"
	role="button"
	tabindex="0"
	aria-label="Flashcard. Press space or click to flip."
	data-flashcard
	data-front={front}
	data-back={back}
>
	<div class="flashcard-inner">
		<div class="flashcard-face flashcard-front">
			<span class="flashcard-tag">Question</span>
			<div class="flashcard-text">{front}</div>
			<span class="flashcard-hint">click to reveal</span>
		</div>
		<div class="flashcard-face flashcard-back">
			<span class="flashcard-tag">Answer</span>
			<div class="flashcard-text">{back}</div>
			<span class="flashcard-hint">click to flip back</span>
		</div>
	</div>
</div>

<script>
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll<HTMLElement>('.flashcard').forEach((card) => {
			const inner = card.querySelector<HTMLElement>('.flashcard-inner')
			if (!inner) return
			let flipped = false
			function flip() {
				if (inner?.classList.contains('is-unflipping')) return
				if (flipped) {
					flipped = false
					inner?.classList.remove('is-flipped')
					inner?.classList.add('is-unflipping')
					setTimeout(() => inner?.classList.remove('is-unflipping'), 400)
				} else {
					flipped = true
					inner?.classList.add('is-flipped')
				}
			}
			card.addEventListener('click', flip)
			card.addEventListener('keydown', (e) => {
				if (e.key === 'Enter') {
					e.preventDefault()
					flip()
				}
			})
		})
	})
</script>

<style>
	.flashcard {
		margin: 1.5em 0;
		cursor: pointer;
		user-select: none;
		perspective: 1200px;
		outline: none;
	}
	.flashcard:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 4px;
		border-radius: var(--radius-2xl);
	}
	.flashcard-inner {
		display: grid;
		min-height: 7rem;
	}
	.flashcard-face {
		grid-area: 1 / 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-2xl);
	}
	.flashcard-front {
		background: var(--card);
	}
	.flashcard-back {
		visibility: hidden;
		background: oklch(from var(--accent-alt) l c h / 0.06);
		border-color: oklch(from var(--accent-alt) l c h / 0.25);
	}
	@keyframes flashcard-flip-out {
		from { transform: rotateX(0deg); }
		to   { transform: rotateX(-90deg); }
	}
	@keyframes flashcard-flip-in {
		from { transform: rotateX(90deg); }
		to   { transform: rotateX(0deg); }
	}
	@keyframes flashcard-flip-reverse-out {
		from { transform: rotateX(0deg); }
		to   { transform: rotateX(90deg); }
	}
	@keyframes flashcard-flip-reverse-in {
		from { transform: rotateX(-90deg); }
		to   { transform: rotateX(0deg); }
	}
	.flashcard-inner.is-flipped .flashcard-front {
		animation: flashcard-flip-out 0.2s ease forwards;
		visibility: hidden;
		transition: visibility 0s 0.2s, opacity 0.2s ease;
	}
	.flashcard-inner.is-flipped .flashcard-back {
		visibility: visible;
		animation: flashcard-flip-in 0.2s ease 0.2s both;
	}
	.flashcard-inner.is-unflipping .flashcard-back {
		animation: flashcard-flip-reverse-out 0.2s ease forwards;
		visibility: hidden;
		transition: visibility 0s 0.2s;
	}
	.flashcard-inner.is-unflipping .flashcard-front {
		visibility: visible;
		animation: flashcard-flip-reverse-in 0.2s ease 0.2s both;
	}
	.flashcard-front .flashcard-tag,
	.flashcard-front .flashcard-text,
	.flashcard-front .flashcard-hint,
	.flashcard-front {
		transition: opacity 0.2s ease;
	}
	.flashcard-inner.is-flipped .flashcard-front .flashcard-tag,
	.flashcard-inner.is-flipped .flashcard-front .flashcard-text,
	.flashcard-inner.is-flipped .flashcard-front,
	.flashcard-inner.is-flipped .flashcard-front {
		opacity: 0;
	}
	.flashcard-inner.is-unflipping .flashcard-front .flashcard-tag,
	.flashcard-inner.is-unflipping .flashcard-front .flashcard-text,
	.flashcard-inner.is-unflipping .flashcard-front,
	.flashcard-inner.is-unflipping .flashcard-front {
		opacity: 1;
		transition: opacity 0.2s ease 0.2s;
	}
	.flashcard-back .flashcard-tag,
	.flashcard-back .flashcard-text {
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.flashcard-inner.is-flipped .flashcard-back .flashcard-tag,
	.flashcard-inner.is-flipped .flashcard-back .flashcard-text {
		opacity: 1;
		transition: opacity 0.2s ease 0.2s;
	}
	.flashcard-inner.is-unflipping .flashcard-back .flashcard-tag,
	.flashcard-inner.is-unflipping .flashcard-back .flashcard-text {
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.flashcard-tag {
		font-size: calc(var(--prose-font-size) * 0.7);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}
	.flashcard-front .flashcard-tag {
		color: var(--accent);
	}
	.flashcard-back .flashcard-tag {
		color: var(--accent-alt-dark);
	}
	.flashcard-text {
		flex: 1;
		line-height: 1.5;
		color: var(--foreground);
	}
	.flashcard-hint {
		margin-top: 0.75rem;
		font-size: 0.7rem;
		color: var(--muted-foreground);
		text-align: right;
		opacity: 0.55;
	}
	@media (prefers-color-scheme: dark) {
		.flashcard-back .flashcard-tag {
			color: var(--accent-alt-light);
		}
		.flashcard-back {
			background: oklch(from var(--accent-alt) l c h / 0.1);
		}
	}
</style>
