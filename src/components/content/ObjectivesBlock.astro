---
import Callout from './Callout.astro'

interface Props {
	objectives: string[]
}
const { objectives } = Astro.props
---

<div class="objectives-wrap">
	<Callout type="tip">
		<span class="objectives-label">After this post</span>
		<ul>
			{objectives.map((obj) => <li>{obj}</li>)}
		</ul>
	</Callout>
</div>

<style>
	.objectives-wrap :global(.callout-icon) {
		display: none;
	}
	.objectives-label {
		display: block;
		font-size: 0.925rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-alt-dark);
		margin-bottom: 0.5rem;
	}
	ul {
		margin: 0;
		padding-left: 1.25rem;
		font-size: 0.925em;
		line-height: 1.6;
	}
	li {
		margin-bottom: 0.2em;
	}
	li:last-child {
		margin-bottom: 0;
	}
	@media (prefers-color-scheme: dark) {
		.objectives-label { color: var(--accent-alt-light); }
	}
</style>
