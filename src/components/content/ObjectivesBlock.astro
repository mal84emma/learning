---
interface Props {
	objectives: string[]
}
const { objectives } = Astro.props
---

<div class="objectives">
	<span class="objectives-label">After this post</span>
	<ul>
		{objectives.map((obj) => <li>{obj}</li>)}
	</ul>
</div>

<style>
	.objectives {
		margin: 1.5em 0;
		padding: 0.85rem 1rem;
		border-left: 3px solid var(--accent-alt);
		border-radius: 0 var(--radius-md) var(--radius-md) 0;
		background: oklch(from var(--accent-alt) l c h / 0.07);
	}
	.objectives-label {
		display: block;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-alt-dark);
		margin-bottom: 0.5rem;
	}
	ul {
		margin: 0;
		padding-left: 1.25rem;
		font-size: 0.925em;
		line-height: 1.6;
	}
	li {
		margin-bottom: 0.2em;
	}
	li:last-child {
		margin-bottom: 0;
	}
	@media (prefers-color-scheme: dark) {
		.objectives-label { color: var(--accent-alt-light); }
	}
</style>
