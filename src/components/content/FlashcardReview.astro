---
// No props — collects flashcards from [data-flashcard] elements at runtime.
---

<div class="fc-wrap" id="fc-wrap" hidden data-pagefind-ignore>
	<button class="fc-trigger" id="fc-trigger" aria-label="Review flashcards">
		<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
			<line x1="8" y1="21" x2="16" y2="21"/>
			<line x1="12" y1="17" x2="12" y2="21"/>
		</svg>
		<span id="fc-trigger-label">Review flashcards</span>
	</button>
</div>

<dialog class="fc-dialog" id="fc-dialog" aria-label="Flashcard review" data-pagefind-ignore>
	<div class="fc-panel">
		<div class="fc-header">
			<div class="fc-meta">
				<span class="fc-progress" id="fc-progress"></span>
				<span class="fc-mastery" id="fc-mastery"></span>
			</div>
			<button class="fc-close" id="fc-close" aria-label="Close review">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>

		<div class="fc-card" id="fc-card">
			<div class="fc-card-inner" id="fc-card-inner">
				<div class="fc-face fc-card-front">
					<span class="fc-face-tag">Question</span>
					<div class="fc-face-text" id="fc-front-text"></div>
					<span class="fc-face-hint">click or press space to reveal</span>
				</div>
				<div class="fc-face fc-card-back">
					<span class="fc-face-tag">Answer</span>
					<div class="fc-face-text" id="fc-back-text"></div>
				</div>
			</div>
		</div>

		<div class="fc-actions" id="fc-actions" hidden>
			<button class="fc-btn fc-btn-again" id="fc-again">
				<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.41"/></svg>
				Again
			</button>
			<button class="fc-btn fc-btn-got-it" id="fc-got-it">
				Got it
				<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
			</button>
		</div>

		<div class="fc-summary" id="fc-summary" hidden>
			<p class="fc-summary-title">Round complete</p>
			<p class="fc-summary-score" id="fc-summary-score"></p>
			<div class="fc-summary-btns">
				<button class="fc-btn fc-btn-again" id="fc-restart">Review again</button>
				<button class="fc-btn fc-btn-got-it" id="fc-done">Done</button>
			</div>
		</div>
	</div>
</dialog>

<script>
	let fcAbort = new AbortController()

	document.addEventListener('astro:before-swap', () => {
		// Reset overflow before the DOM swap in case the dialog was open during navigation.
		document.body.style.overflow = ''
		fcAbort.abort()
		fcAbort = new AbortController()
	})

	document.addEventListener('astro:page-load', () => {
		const { signal } = fcAbort

		const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-flashcard]')).map(
			(el, i) => ({ id: i, front: el.dataset.front ?? '', back: el.dataset.back ?? '' })
		)

		const wrap = document.getElementById('fc-wrap')
		const triggerLabel = document.getElementById('fc-trigger-label')
		const trigger = document.getElementById('fc-trigger') as HTMLButtonElement | null
		const dialog = document.getElementById('fc-dialog') as HTMLDialogElement | null
		const closeBtn = document.getElementById('fc-close') as HTMLButtonElement | null
		const progressEl = document.getElementById('fc-progress')
		const masteryEl = document.getElementById('fc-mastery')
		const cardEl = document.getElementById('fc-card')
		const cardInner = document.getElementById('fc-card-inner')
		const frontText = document.getElementById('fc-front-text')
		const backText = document.getElementById('fc-back-text')
		const actionsEl = document.getElementById('fc-actions')
		const againBtn = document.getElementById('fc-again') as HTMLButtonElement | null
		const gotItBtn = document.getElementById('fc-got-it') as HTMLButtonElement | null
		const summaryEl = document.getElementById('fc-summary')
		const summaryScore = document.getElementById('fc-summary-score')
		const restartBtn = document.getElementById('fc-restart') as HTMLButtonElement | null
		const doneBtn = document.getElementById('fc-done') as HTMLButtonElement | null

		if (!wrap || !dialog || !trigger || cards.length === 0) return

		wrap.hidden = false
		if (triggerLabel) triggerLabel.textContent = `Review ${cards.length} flashcard${cards.length !== 1 ? 's' : ''}`

		const storageKey = `learning-flashcards-${window.location.pathname}`
		const getMastered = () =>
			new Set<number>(JSON.parse(localStorage.getItem(storageKey) ?? '[]') as number[])
		const saveMastered = (m: Set<number>) =>
			localStorage.setItem(storageKey, JSON.stringify([...m]))

		let queue: number[] = []
		let queuePos = 0
		let mastered = new Set<number>()
		let isFlipped = false

		function updateMeta() {
			if (progressEl) progressEl.textContent = `${queuePos + 1} / ${queue.length}`
			if (masteryEl) masteryEl.textContent = `${mastered.size} mastered`
		}

		function showCard(pos: number) {
			const card = cards[queue[pos]]
			isFlipped = false
			cardInner?.classList.remove('is-flipped')
			if (frontText) frontText.textContent = card.front
			if (backText) backText.textContent = card.back
			if (actionsEl) actionsEl.hidden = true
			cardEl?.classList.toggle('fc-card-mastered', mastered.has(card.id))
			updateMeta()
		}

		function flip() {
			if (isFlipped) return
			isFlipped = true
			cardInner?.classList.add('is-flipped')
			if (actionsEl) actionsEl.hidden = false
			setTimeout(() => gotItBtn?.focus(), 50)
		}

		function advance() {
			queuePos++
			if (queuePos >= queue.length) {
				showSummary()
			} else {
				showCard(queuePos)
			}
		}

		function showSummary() {
			if (cardEl) cardEl.hidden = true
			if (actionsEl) actionsEl.hidden = true
			if (progressEl) progressEl.textContent = 'Done!'
			if (masteryEl) masteryEl.textContent = ''
			if (summaryEl) summaryEl.hidden = false
			if (summaryScore) {
				summaryScore.textContent = `${mastered.size} of ${cards.length} mastered`
			}
			setTimeout(() => doneBtn?.focus(), 50)
		}

		function openReview() {
			mastered = getMastered()
			queue = cards.map((_, i) => i)
			queuePos = 0
			if (cardEl) cardEl.hidden = false
			if (summaryEl) summaryEl.hidden = true
			dialog.showModal()
			document.body.style.overflow = 'hidden'
			showCard(0)
		}

		function closeReview() {
			dialog.close()
			document.body.style.overflow = ''
			trigger.focus()
		}

		trigger.addEventListener('click', openReview, { signal })
		closeBtn?.addEventListener('click', closeReview, { signal })
		cardEl?.addEventListener('click', () => flip(), { signal })

		againBtn?.addEventListener('click', () => {
			mastered.delete(cards[queue[queuePos]].id)
			saveMastered(mastered)
			advance()
		}, { signal })

		gotItBtn?.addEventListener('click', () => {
			mastered.add(cards[queue[queuePos]].id)
			saveMastered(mastered)
			advance()
		}, { signal })

		restartBtn?.addEventListener('click', openReview, { signal })
		doneBtn?.addEventListener('click', closeReview, { signal })

		// Native dialog close fires on Escape — sync state.
		dialog.addEventListener('close', () => {
			document.body.style.overflow = ''
			trigger.focus()
		}, { signal })

		document.addEventListener('keydown', (e) => {
			const active = document.activeElement as HTMLElement | null
			const inInput = active && ['INPUT', 'TEXTAREA', 'SELECT'].includes(active.tagName)

			if (!dialog.open) {
				if (e.key === 'r' && !inInput && !active?.isContentEditable && !document.querySelector('dialog[open]')) {
					openReview()
				}
				return
			}

			// Space/Enter flip the card unless a button is focused (let browser handle that).
			if ((e.key === ' ' || e.key === 'Enter') && active?.tagName !== 'BUTTON') {
				e.preventDefault()
				flip()
			}
			if (!actionsEl?.hidden) {
				if (e.key === 'g' || e.key === 'y') gotItBtn?.click()
				if (e.key === 'n') againBtn?.click()
			}
		}, { signal })
	})
</script>

<style>
	/* Trigger */
	.fc-wrap {
		display: flex;
		justify-content: center;
		padding-top: 2em;
		margin-top: 2.5em;
		border-top: 1px solid oklch(from var(--foreground) l c h / 8%);
	}
	.fc-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.5em 1.25em;
		background: color-mix(in oklch, var(--input) 30%, transparent);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: calc(var(--radius) * 1.5);
		color: color-mix(in oklch, var(--foreground) 80%, var(--background));
		font-family: inherit;
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s, color 0.2s;
	}
	.fc-trigger:hover {
		background: color-mix(in oklch, var(--input) 55%, transparent);
		color: var(--foreground);
	}

	/* Dialog — overflow: clip clips to border-radius without forming a stacking context
	   that would flatten transform-style: preserve-3d on child card elements. */
	:global(.fc-dialog) {
		margin: auto;
		width: min(620px, calc(100vw - 2rem));
		padding: 0;
		background: var(--background);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-2xl);
		box-shadow: 0 16px 64px oklch(0 0 0 / 18%);
		overflow: clip;
	}
	:global(.fc-dialog::backdrop) {
		background: oklch(0 0 0 / 50%);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}
	@media (prefers-color-scheme: dark) {
		:global(.fc-dialog) {
			box-shadow: 0 16px 64px oklch(0 0 0 / 50%);
		}
		:global(.fc-dialog::backdrop) {
			background: oklch(0 0 0 / 65%);
		}
	}

	/* Panel */
	.fc-panel {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.5rem;
	}

	/* Header */
	.fc-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.fc-meta {
		display: flex;
		gap: 1.25rem;
		font-size: 0.8rem;
		color: var(--muted-foreground);
	}
	.fc-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		background: none;
		border: none;
		border-radius: var(--radius-md);
		color: var(--muted-foreground);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.fc-close:hover {
		background: oklch(from var(--foreground) l c h / 8%);
		color: var(--foreground);
	}

	/* Review card — same 3D flip as inline Flashcard component */
	.fc-card {
		perspective: 1200px;
		cursor: pointer;
	}
	.fc-card-inner {
		display: grid;
		min-height: 9rem;
		transform-style: preserve-3d;
		transition: transform 0.4s ease;
	}
	.fc-card-inner.is-flipped {
		transform: rotateY(180deg);
	}
	.fc-face {
		grid-area: 1 / 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.5rem;
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-xl);
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
	}
	.fc-card-front {
		background: var(--card);
	}
	.fc-card-back {
		transform: rotateY(180deg);
		background: oklch(from var(--accent-alt) l c h / 0.06);
		border-color: oklch(from var(--accent-alt) l c h / 0.25);
	}
	/* Subtle ring when the card has already been mastered */
	.fc-card-mastered .fc-card-front {
		border-color: oklch(from var(--accent-alt) l c h / 0.4);
		background: oklch(from var(--accent-alt) l c h / 0.04);
	}
	.fc-face-tag {
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}
	.fc-card-front .fc-face-tag {
		color: var(--accent);
	}
	.fc-card-back .fc-face-tag {
		color: var(--accent-alt-dark);
	}
	.fc-face-text {
		flex: 1;
		font-size: 1.05rem;
		line-height: 1.5;
		color: var(--foreground);
	}
	.fc-face-hint {
		margin-top: 0.75rem;
		font-size: 0.7rem;
		color: var(--muted-foreground);
		text-align: right;
		opacity: 0.5;
	}

	/* Actions */
	.fc-actions {
		display: flex;
		gap: 0.75rem;
	}
	.fc-btn {
		flex: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		padding: 0.6em 1em;
		border-radius: var(--radius-xl);
		font-family: inherit;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.fc-btn-again {
		background: color-mix(in oklch, var(--input) 30%, transparent);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		color: var(--foreground);
	}
	.fc-btn-again:hover {
		background: color-mix(in oklch, var(--input) 55%, transparent);
	}
	.fc-btn-got-it {
		background: oklch(from var(--accent-alt) l c h / 0.12);
		border: 1px solid oklch(from var(--accent-alt) l c h / 0.3);
		color: var(--accent-alt-dark);
	}
	.fc-btn-got-it:hover {
		background: oklch(from var(--accent-alt) l c h / 0.22);
	}

	/* Summary */
	.fc-summary {
		padding: 0.5rem 0 0.75rem;
		text-align: center;
	}
	.fc-summary-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--foreground);
		margin: 0 0 0.25rem;
	}
	.fc-summary-score {
		color: var(--muted-foreground);
		font-size: 0.875rem;
		margin: 0 0 1.25rem;
	}
	.fc-summary-btns {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
	}
	.fc-summary-btns .fc-btn {
		flex: 0 0 auto;
		padding: 0.6em 1.5em;
	}

	@media (prefers-color-scheme: dark) {
		.fc-card-back .fc-face-tag {
			color: var(--accent-alt-light);
		}
		.fc-card-back {
			background: oklch(from var(--accent-alt) l c h / 0.1);
		}
		.fc-btn-got-it {
			color: var(--accent-alt-light);
		}
	}
</style>
