---
interface Props {
	cards: Array<{ id: string; postTitle: string; front: string; back: string }>;
}
const { cards } = Astro.props;
---

<div id="fc-data" data-cards={JSON.stringify(cards)} hidden></div>
<dialog id="fc-review-dialog" class="fc-review-dialog" aria-label="Flashcard review">
	<div class="fc-panel">
		<div class="fc-header">
			<div class="fc-meta">
				<span class="fc-progress" id="fc-progress"></span>
				<span class="fc-mastery" id="fc-mastery"></span>
			</div>
			<button class="fc-close" id="fc-close" aria-label="Close review">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>

		<div class="fc-card" id="fc-card">
			<div class="fc-card-inner" id="fc-card-inner">
				<div class="fc-face fc-card-front">
					<div class="fc-face-header">
						<span class="fc-face-tag">Question</span>
						<span class="fc-post-title" id="fc-post-title"></span>
					</div>
					<div class="fc-face-text" id="fc-front-text"></div>
					<span class="fc-face-hint">click to reveal</span>
				</div>
				<div class="fc-face fc-card-back">
					<span class="fc-face-tag">Answer</span>
					<div class="fc-face-text" id="fc-back-text"></div>
				</div>
			</div>
		</div>

		<div class="fc-actions" id="fc-actions">
			<button class="fc-btn fc-btn-again" id="fc-again">
				<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.41"/></svg>
				Try again
			</button>
			<button class="fc-btn fc-btn-got-it" id="fc-got-it">
				I got it
				<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
			</button>
		</div>

		<div class="fc-summary" id="fc-summary" hidden>
			<p class="fc-summary-title">Round complete</p>
			<p class="fc-summary-score" id="fc-summary-score"></p>
			<div class="fc-summary-btns">
				<button class="fc-btn fc-btn-again" id="fc-restart">Review again</button>
				<button class="fc-btn fc-btn-got-it" id="fc-done">Done</button>
			</div>
		</div>
	</div>
</dialog>

<script>
	type Card = { id: string; postTitle: string; front: string; back: string }

	let reviewAbort = new AbortController();

	// Close before startViewTransition captures the outgoing screenshot.
	// astro:before-swap fires inside that callback — too late to prevent the flash.
	document.addEventListener('astro:before-preparation', () => {
		const dialog = document.getElementById('fc-review-dialog') as HTMLDialogElement | null;
		if (dialog?.open) {
			dialog.close();
			document.body.style.overflow = '';
		}
	});

	document.addEventListener('astro:before-swap', () => {
		reviewAbort.abort();
		reviewAbort = new AbortController();
	});

	document.addEventListener('astro:page-load', () => {
		const fcData = document.getElementById('fc-data');
		const reviewDialog = document.getElementById('fc-review-dialog') as HTMLDialogElement | null;
		if (!fcData || !reviewDialog) return;

		const { signal } = reviewAbort;
		const allCards: Card[] = JSON.parse(fcData.dataset.cards ?? '[]');

		function shuffle(arr: Card[]): Card[] {
			const a = [...arr];
			for (let i = a.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[a[i], a[j]] = [a[j], a[i]];
			}
			return a;
		}

		const storageKey = 'learning-flashcards-global';
		const getMastered = () => new Set<string>(JSON.parse(localStorage.getItem(storageKey) ?? '[]') as string[]);
		const saveMastered = (m: Set<string>) => localStorage.setItem(storageKey, JSON.stringify([...m]));

		const progressEl   = document.getElementById('fc-progress');
		const masteryEl    = document.getElementById('fc-mastery');
		const cardEl       = document.getElementById('fc-card');
		const cardInner    = document.getElementById('fc-card-inner');
		const postTitleEl  = document.getElementById('fc-post-title');
		const frontText    = document.getElementById('fc-front-text');
		const backText     = document.getElementById('fc-back-text');
		const actionsEl    = document.getElementById('fc-actions');
		const againBtn     = document.getElementById('fc-again')   as HTMLButtonElement | null;
		const gotItBtn     = document.getElementById('fc-got-it')  as HTMLButtonElement | null;
		const summaryEl    = document.getElementById('fc-summary');
		const summaryScore = document.getElementById('fc-summary-score');
		const restartBtn   = document.getElementById('fc-restart') as HTMLButtonElement | null;
		const doneBtn      = document.getElementById('fc-done')    as HTMLButtonElement | null;
		const closeBtn     = document.getElementById('fc-close')   as HTMLButtonElement | null;

		let queue: Card[] = [];
		let queuePos = 0;
		let mastered = new Set<string>();
		let isFlipped = false;

		function updateMeta() {
			if (progressEl) progressEl.textContent = `${queuePos + 1} / ${queue.length}`;
			if (masteryEl)  masteryEl.textContent  = `${mastered.size} mastered`;
		}

		function showCard(pos: number) {
			const card = queue[pos];
			isFlipped = false;
			cardInner?.classList.remove('is-flipped');
			if (frontText)   frontText.textContent   = card.front;
			if (backText)    backText.textContent    = card.back;
			if (postTitleEl) postTitleEl.textContent = card.postTitle;
			actionsEl?.classList.remove('is-visible');
			cardEl?.classList.toggle('fc-card-mastered', mastered.has(card.id));
			updateMeta();
		}

		function flip() {
			if (isFlipped || cardInner?.classList.contains('is-unflipping')) return;
			isFlipped = true;
			cardInner?.classList.add('is-flipped');
			setTimeout(() => {
				actionsEl?.classList.add('is-visible');
				gotItBtn?.focus();
			}, 400);
		}


		function showSummary() {
			if (cardEl)     cardEl.hidden              = true;
			actionsEl?.classList.remove('is-visible');
			if (progressEl) progressEl.textContent     = 'Done!';
			if (masteryEl)  masteryEl.textContent      = '';
			if (summaryEl)  summaryEl.hidden           = false;
			if (summaryScore) summaryScore.textContent = `${mastered.size} of ${allCards.length} mastered`;
			setTimeout(() => doneBtn?.focus(), 50);
		}

		function openReview() {
			mastered = getMastered();
			queue    = shuffle(allCards);
			queuePos = 0;
			if (cardEl)    cardEl.hidden    = false;
			if (summaryEl) summaryEl.hidden = true;
			reviewDialog!.showModal();
			document.body.style.overflow = 'hidden';
			showCard(0);
		}

		function closeReview() {
			reviewDialog!.close();
			document.body.style.overflow = '';
		}

		document.addEventListener('open-flashcard-review', openReview, { signal });
		closeBtn?.addEventListener('click', closeReview, { signal });
		cardEl?.addEventListener('click', () => flip(), { signal });

		againBtn?.addEventListener('click', () => {
			mastered.delete(queue[queuePos].id);
			saveMastered(mastered);
			isFlipped = false;
			cardInner?.classList.remove('is-flipped');
			cardInner?.classList.add('is-unflipping');
			actionsEl?.classList.remove('is-visible');
			setTimeout(() => cardInner?.classList.remove('is-unflipping'), 400);
		}, { signal });

		gotItBtn?.addEventListener('click', () => {
			mastered.add(queue[queuePos].id);
			saveMastered(mastered);
			isFlipped = false;
			cardInner?.classList.remove('is-flipped');
			actionsEl?.classList.remove('is-visible');

			if (!cardEl) {
				queuePos++;
				if (queuePos >= queue.length) showSummary();
				else showCard(queuePos);
				return;
			}

			const h0 = cardEl.offsetHeight;
			cardEl.style.opacity = '0';
			cardEl.style.transition = 'opacity 0.12s ease';

			setTimeout(() => {
				queuePos++;
				if (queuePos >= queue.length) {
					cardEl.style.opacity = '';
					cardEl.style.transition = '';
					showSummary();
					return;
				}
				showCard(queuePos);

				const h1 = cardEl.offsetHeight;
				if (h1 !== h0) cardEl.style.height = `${h0}px`;

				requestAnimationFrame(() => {
					cardEl.style.transition = `opacity 0.15s ease${h1 !== h0 ? ', height 0.25s ease' : ''}`;
					cardEl.style.opacity = '1';
					if (h1 !== h0) cardEl.style.height = `${h1}px`;
					setTimeout(() => {
						cardEl.style.opacity = '';
						cardEl.style.transition = '';
						cardEl.style.height = '';
					}, 250);
				});
			}, 120);
		}, { signal });

		restartBtn?.addEventListener('click', openReview, { signal });
		doneBtn?.addEventListener('click', closeReview, { signal });

		reviewDialog.addEventListener('close', () => {
			document.body.style.overflow = '';
		}, { signal });

		document.addEventListener('keydown', (e) => {
			if (e.metaKey || e.ctrlKey || e.altKey) return;
			const active = document.activeElement as HTMLElement | null;
			if (reviewDialog.open) {
				if (e.key === 'Enter' && active?.tagName !== 'BUTTON') {
					e.preventDefault();
					flip();
				}
				if (actionsEl?.classList.contains('is-visible')) {
					if (e.key === 'g' || e.key === 'y') gotItBtn?.click();
					if (e.key === 'n') againBtn?.click();
				}
			} else {
				const inInput = active && ['INPUT', 'TEXTAREA', 'SELECT'].includes(active.tagName);
				if (e.key === 'r' && !inInput && !active?.isContentEditable && !document.querySelector('dialog[open]')) {
					openReview();
				}
			}
		}, { signal });
	});
</script>

<style>
	:global(.fc-review-dialog:not([open])) {
		display: none;
	}
	:global(.fc-review-dialog) {
		margin: auto;
		width: min(620px, calc(100vw - 2rem));
		padding: 0;
		background: var(--background);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-2xl);
		box-shadow: 0 16px 64px oklch(0 0 0 / 18%);
		overflow: clip;
	}
	:global(.fc-review-dialog::backdrop) {
		background: oklch(0 0 0 / 50%);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}
	.fc-panel {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1rem 1.25rem;
		transition: 0.2s ease;
	}
	.fc-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.fc-meta {
		display: flex;
		gap: 1.25rem;
		font-size: 0.8rem;
		color: var(--muted-foreground);
	}
	.fc-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		background: none;
		border: none;
		border-radius: var(--radius-md);
		color: var(--muted-foreground);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.fc-close:hover {
		background: oklch(from var(--foreground) l c h / 8%);
		color: var(--foreground);
	}
	.fc-card {
		perspective: 1200px;
		cursor: pointer;
	}
	.fc-card-inner {
		display: grid;
		min-height: 9rem;
	}
	.fc-face {
		grid-area: 1 / 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1rem 1.5rem;
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-xl);
	}
	.fc-card-front {
		background: var(--card);
	}
	.fc-card-back {
		visibility: hidden;
		background: oklch(from var(--accent-alt) l c h / 0.06);
		border-color: oklch(from var(--accent-alt) l c h / 0.25);
	}
	.fc-card-mastered .fc-card-front {
		border-color: oklch(from var(--accent-alt) l c h / 0.4);
		background: oklch(from var(--accent-alt) l c h / 0.04);
	}
	@keyframes fc-flip-out {
		from { transform: rotateX(0deg); }
		to   { transform: rotateX(-90deg); }
	}
	@keyframes fc-flip-in {
		from { transform: rotateX(90deg); }
		to   { transform: rotateX(0deg); }
	}
	@keyframes fc-flip-reverse-out {
		from { transform: rotateX(0deg); }
		to   { transform: rotateX(90deg); }
	}
	@keyframes fc-flip-reverse-in {
		from { transform: rotateX(-90deg); }
		to   { transform: rotateX(0deg); }
	}
	.fc-card-inner.is-flipped .fc-card-front {
		animation: fc-flip-out 0.2s ease forwards;
		visibility: hidden;
		transition: visibility 0s 0.2s, opacity 0.2s ease;
	}
	.fc-card-inner.is-flipped .fc-card-back {
		visibility: visible;
		animation: fc-flip-in 0.2s ease 0.2s both;
	}
	.fc-card-inner.is-unflipping .fc-card-back {
		animation: fc-flip-reverse-out 0.2s ease forwards;
		visibility: hidden;
		transition: visibility 0s 0.2s;
	}
	.fc-card-inner.is-unflipping .fc-card-front {
		visibility: visible;
		animation: fc-flip-reverse-in 0.2s ease 0.2s both;
	}
	.fc-card-front .fc-face-header,
	.fc-card-front .fc-face-text,
	.fc-card-front {
		transition: opacity 0.2s ease;
	}
	.fc-card-inner.is-flipped .fc-card-front .fc-face-header,
	.fc-card-inner.is-flipped .fc-card-front .fc-face-text,
	.fc-card-inner.is-flipped .fc-card-front {
		opacity: 0;
	}
	.fc-card-inner.is-unflipping .fc-card-front .fc-face-header,
	.fc-card-inner.is-unflipping .fc-card-front .fc-face-text,
	.fc-card-inner.is-unflipping .fc-card-front .fc-actions {
		opacity: 1;
		transition: opacity 0.2s ease 0.2s;
	}
	.fc-card-back .fc-face-tag,
	.fc-card-back .fc-face-text {
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.fc-card-inner.is-flipped .fc-card-back .fc-face-tag,
	.fc-card-inner.is-flipped .fc-card-back .fc-face-text {
		opacity: 1;
		transition: opacity 0.2s ease 0.2s;
	}
	.fc-card-inner.is-unflipping .fc-card-back .fc-face-tag,
	.fc-card-inner.is-unflipping .fc-card-back .fc-face-text {
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.fc-face-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.25rem;
	}
	.fc-face-tag {
		font-size: calc(var(--prose-font-size) * 0.7);
		font-weight:600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	.fc-card-front .fc-face-tag { color: var(--accent); }
	.fc-card-back .fc-face-tag { color: var(--accent-alt-dark); }
	.fc-post-title {
		font-size: calc(var(--prose-font-size) * 0.65);
		color: var(--muted-foreground);
		opacity: 0.7;
	}
	.fc-face-text {
		flex: 1;
		font-size: var(--prose-font-size);
		line-height: 1.5;
		color: var(--foreground);
	}
	.fc-face-hint {
		margin-top: 0.75rem;
		font-size: 0.7rem;
		color: var(--muted-foreground);
		text-align: right;
		opacity: 0.5;
	}
	.fc-actions {
		display: flex;
		gap: 0.75rem;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		margin-top: -0.75rem;
		pointer-events: none;
		transition: max-height 0.5s ease, opacity 0.25s ease, margin-top 0.5s ease;
	}
	.fc-actions.is-visible {
		max-height: 4rem;
		opacity: 1;
		margin-top: 0;
		pointer-events: auto;
		transition: max-height 0.5s ease, opacity 0.25s ease, margin-top 0.5s ease;
	}
	.fc-btn {
		flex: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		padding: 0.6em 1em;
		border-radius: var(--radius-xl);
		font-family: inherit;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s, color 0.2s, opacity 0.2s;
	}
	.fc-btn-again {
		background: color-mix(in oklch, var(--input) 30%, transparent);
		border: 1px solid oklch(50% 0.125 55);
		color: oklch(75% 0.125 55);
	}
	.fc-btn-again:hover { background: color-mix(in oklch, var(--input) 55%, transparent); }
	.fc-btn-got-it {
		background: color-mix(in oklch, var(--input) 30%, transparent);
		border: 1px solid oklch(from var(--accent-alt) l c h / 0.3);
		color: var(--accent-alt-dark);
	}
	.fc-btn-got-it:hover { background: oklch(from var(--accent-alt) l c h / 0.22); }
	.fc-summary {
		padding: 0.5rem 0 0.75rem;
		text-align: center;
	}
	.fc-summary-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--foreground);
		margin: 0 0 0.25rem;
	}
	.fc-summary-score {
		color: var(--muted-foreground);
		font-size: 0.875rem;
		margin: 0 0 1.25rem;
	}
	.fc-summary-btns {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
	}
	.fc-summary-btns .fc-btn {
		flex: 0 0 auto;
		padding: 0.6em 1.5em;
	}

	@media (prefers-color-scheme: dark) {
		:global(.fc-review-dialog) {
			box-shadow: 0 16px 64px oklch(0 0 0 / 50%);
		}
		:global(.fc-review-dialog::backdrop) {
			background: oklch(0 0 0 / 65%);
		}
		.fc-card-back .fc-face-tag { color: var(--accent-alt-light); }
		.fc-card-back { background: oklch(from var(--accent-alt) l c h / 0.1); }
		.fc-btn-got-it { color: var(--accent-alt-light); }
	}
</style>
