<div id="page-scrollbar">
	<div id="page-scrollbar-thumb"></div>
</div>

<style is:global>
	#page-scrollbar {
		position: fixed;
		right: 0;
		top: 0;
		bottom: 0;
		width: 5px;
		pointer-events: none;
		z-index: 0;
	}
	#page-scrollbar-thumb {
		position: absolute;
		right: 0;
		width: 5px;
		background: rgb(var(--gray-dark));
	}
	@media (prefers-color-scheme: dark) {
		#page-scrollbar-thumb {
			background: rgb(var(--gray-light));
		}
	}

</style>

<script>
	let abortController: AbortController | null = null;

	function initScrollbar() {
		abortController?.abort();
		abortController = new AbortController();

		const pageThumb = document.getElementById('page-scrollbar-thumb');
		if (!pageThumb) return;

		function updatePageThumb() {
			const scrollHeight = document.documentElement.scrollHeight;
			const clientHeight = window.innerHeight;
			const ratio = clientHeight / scrollHeight;
			const thumbHeight = clientHeight * ratio;
			const thumbTop = (window.scrollY / scrollHeight) * clientHeight;
			pageThumb.style.height = `${thumbHeight}px`;
			pageThumb.style.top = `${thumbTop}px`;
		}

		window.addEventListener('scroll', updatePageThumb, { passive: true, signal: abortController.signal });
		updatePageThumb();
	}

	document.addEventListener('astro:page-load', initScrollbar);
</script>
