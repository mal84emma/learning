---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

type Heading = { depth: number; slug: string; text: string };
interface Props { headings?: Heading[] }

const { headings = [] } = Astro.props;
const h1s = headings.filter((h) => h.depth === 1 || h.depth === 2);

const posts = (await getCollection('blog')).sort(
	(a, b) => (a.data.orderingNumber) - (b.data.orderingNumber),
);

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const allCards = posts.flatMap((post) =>
	(post.data.flashcards ?? []).map((card, i) => ({
		id: `${post.id}-${i}`,
		postTitle: post.data.shortTitle,
		front: card.front,
		back: card.back,
	}))
);
---

<aside id="sidebar" data-pagefind-ignore>
	<script is:inline>
		// Apply collapsed state synchronously before first paint to avoid flash
		const savedState = localStorage.getItem('sidebar-collapsed');
		if (savedState === 'true' || (savedState === null && window.innerWidth < 1000)) {
			document.getElementById('sidebar').classList.add('collapsed');
			document.body.classList.add('sidebar-collapsed');
		}
		const savedFontSize = localStorage.getItem('learning-font-size');
		if (savedFontSize) document.documentElement.classList.add(savedFontSize);
	</script>
	<div class="nav-scrollbar" id="nav-scrollbar">
		<div class="nav-scrollbar-thumb" id="nav-scrollbar-thumb"></div>
	</div>
	<div class="sidebar-actions">
		<button id="shortcuts-btn" aria-label="Keyboard shortcuts">?</button>
		<button id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="true">
			<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="3" y1="6" x2="21" y2="6" />
				<line x1="3" y1="12" x2="21" y2="12" />
				<line x1="3" y1="18" x2="21" y2="18" />
			</svg>
		</button>
	</div>
	<nav>
		<div class="nav-header">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
			<button id="search-btn" aria-label="Search">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8" />
					<line x1="21" y1="21" x2="16.65" y2="16.65" />
				</svg>
			</button>
		</div>
		<div class="nav-links">
			{posts.map((post) => {
				const postHref = `${base}/blog/${post.id}`;
				const isActive = currentPath === postHref;
				return (
					<>
						<a href={postHref} class={isActive ? 'active' : ''}>
							{post.data.title}
						</a>
						{isActive && h1s.length > 0 && (
							<div class="headings">
								{h1s.map((h) => (
									<a href={`#${h.slug}`} class={`heading-link heading-h${h.depth}`}>
										{h.text}
									</a>
								))}
							</div>
						)}
					</>
				);
			})}
		</div>
		{allCards.length > 0 && (
			<div class="nav-footer">
				<button id="fc-review-btn" class="fc-review-btn" aria-label="Review all flashcards">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
						<line x1="8" y1="21" x2="16" y2="21"/>
						<line x1="12" y1="17" x2="12" y2="21"/>
					</svg>
					Review
					<span class="fc-count">{allCards.length}</span>
				</button>
			</div>
		)}
	</nav>
	{allCards.length > 0 && (
		<>
			<div id="fc-data" data-cards={JSON.stringify(allCards)} hidden></div>
			<dialog id="fc-review-dialog" class="fc-review-dialog" aria-label="Flashcard review">
				<div class="fc-panel">
					<div class="fc-header">
						<div class="fc-meta">
							<span class="fc-progress" id="fc-progress"></span>
							<span class="fc-mastery" id="fc-mastery"></span>
						</div>
						<button class="fc-close" id="fc-close" aria-label="Close review">
							<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<line x1="18" y1="6" x2="6" y2="18"/>
								<line x1="6" y1="6" x2="18" y2="18"/>
							</svg>
						</button>
					</div>

					<div class="fc-card" id="fc-card">
						<div class="fc-card-inner" id="fc-card-inner">
							<div class="fc-face fc-card-front">
								<div class="fc-face-header">
									<span class="fc-face-tag">Question</span>
									<span class="fc-post-title" id="fc-post-title"></span>
								</div>
								<div class="fc-face-text" id="fc-front-text"></div>
								<span class="fc-face-hint">click or press space to reveal</span>
							</div>
							<div class="fc-face fc-card-back">
								<span class="fc-face-tag">Answer</span>
								<div class="fc-face-text" id="fc-back-text"></div>
							</div>
						</div>
					</div>

					<div class="fc-actions" id="fc-actions" hidden>
						<button class="fc-btn fc-btn-again" id="fc-again">
							<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.41"/></svg>
							Again
						</button>
						<button class="fc-btn fc-btn-got-it" id="fc-got-it">
							Got it
							<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
						</button>
					</div>

					<div class="fc-summary" id="fc-summary" hidden>
						<p class="fc-summary-title">Round complete</p>
						<p class="fc-summary-score" id="fc-summary-score"></p>
						<div class="fc-summary-btns">
							<button class="fc-btn fc-btn-again" id="fc-restart">Review again</button>
							<button class="fc-btn fc-btn-got-it" id="fc-done">Done</button>
						</div>
					</div>
				</div>
			</dialog>
		</>
	)}
</aside>

<style>
	.sidebar-actions {
		position: absolute;
		top: 1rem;
		right: 0.5rem;
		z-index: 2;
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	#shortcuts-btn,
	#sidebar-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		background: var(--background);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		color: rgb(var(--gray-dark));
		cursor: pointer;
		box-shadow: 0 1px 4px rgba(var(--black), 8%);
		transition: color 0.2s ease;
	}
	#shortcuts-btn {
		font-size: 0.85rem;
		font-weight: 600;
		font-family: inherit;
		transition: color 0.2s ease, opacity 0.4s ease;
	}
	aside.collapsed #shortcuts-btn {
		opacity: 0;
		pointer-events: none;
	}
	#shortcuts-btn:hover,
	#sidebar-toggle:hover {
		color: var(--accent);
	}
	aside {
		position: fixed;
		top: 0;
		left: 0;
		width: var(--sidebar-width);
		height: 100vh;
		background: var(--background);
		border-right: 1px solid rgb(var(--gray-light));
		box-shadow: 2px 0 8px rgba(var(--black), 5%);
		z-index: 100;
		transition:
			transform 1s ease,
			background-color 1.25s ease,
			border-color 1.25s ease,
			box-shadow 1.25s ease;
	}
	aside.collapsed {
		transform: translateX(calc(3.25rem - var(--sidebar-width)));
		background-color: transparent;
		border-color: transparent;
		box-shadow: none;
	}
	aside.collapsed nav {
		opacity: 0;
	}
	nav {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 4em 0 2em;
		overflow-y: auto;
		scrollbar-width: none;
		transition: opacity 0.5s ease;
		position: relative;
		z-index: 1;
	}
	nav::-webkit-scrollbar {
		display: none;
	}
	.nav-scrollbar {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 1px;
		pointer-events: none;
		z-index: 0;
	}
	.nav-scrollbar-thumb {
		position: absolute;
		left: 0;
		width: 5px;
		background: rgb(var(--gray-dark));
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.nav-scrollbar-thumb.visible {
		opacity: 1;
	}
	.nav-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-right: 0.75em;
		margin-bottom: 2em;
	}
	#search-btn {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		padding: 0;
		background: none;
		border: none;
		border-radius: var(--radius-sm);
		color: rgb(var(--gray));
		cursor: pointer;
		transition: color 0.2s ease;
	}
	#search-btn:hover {
		color: var(--accent);
	}
	aside.collapsed :global(#search-btn) {
		opacity: 0;
		pointer-events: none;
	}
	h2 {
		margin: 0;
		padding: 0 0 0 1.5em;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 700;
		font-size: 1.25em;
		transition: color 0.2s ease;
	}
	h2 a:hover,
	h2 a.active:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
	.nav-links :global(a) {
		display: block;
		padding: 0.75em 1.5em;
		color: rgb(var(--gray-dark));
		border-left: 4px solid transparent;
		border-bottom: none;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.nav-links :global(a.active) {
		border-left-color: var(--accent);
		color: var(--accent);
	}
	.nav-links :global(a:hover) {
		color: var(--accent);
	}
	.headings {
		display: flex;
		flex-direction: column;
	}
	.nav-links :global(a.heading-link) {
		padding: 0.25em 1.5em 0.25em 2.5em;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		transition: color 1.5s ease, border-left-color 1.5s ease;
	}
	.nav-links :global(a.heading-link:hover) {
		color: var(--accent-alt-dark) !important;
	}
	.nav-links :global(a.heading-h2) {
		padding-left: 3.5em;
	}
	.nav-links :global(a.heading-link.active-section) {
		color: var(--accent-alt-dark);
		opacity: 1;
		border-left-color: var(--accent-alt-dark);
	}
	.nav-links :global(a.heading-link[data-visited]:not(.active-section)) {
		opacity: 0.4;
	}
	.social-links {
		display: flex;
		flex-direction: row;
		gap: 0.75em;
		margin-top: auto;
		padding: 0 1.5em;
	}
	.social-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	/* Review button */
	.nav-footer {
		margin-top: auto;
		padding: 0.75em 1.5em 1em;
		border-top: 1px solid oklch(from var(--foreground) l c h / 7%);
	}
	.fc-review-btn {
		display: flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.4em 0;
		background: none;
		border: none;
		color: rgb(var(--gray));
		font-family: inherit;
		font-size: 0.85em;
		cursor: pointer;
		transition: color 0.2s;
	}
	.fc-review-btn:hover { color: var(--accent); }
	.fc-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.4em;
		height: 1.4em;
		padding: 0 0.3em;
		background: oklch(from var(--foreground) l c h / 8%);
		border-radius: 999px;
		font-size: 0.75em;
	}

	/* Review dialog */
	:global(.fc-review-dialog) {
		margin: auto;
		width: min(620px, calc(100vw - 2rem));
		padding: 0;
		background: var(--background);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-2xl);
		box-shadow: 0 16px 64px oklch(0 0 0 / 18%);
		overflow: clip;
	}
	:global(.fc-review-dialog::backdrop) {
		background: oklch(0 0 0 / 50%);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}
	.fc-panel {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.5rem;
	}
	.fc-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.fc-meta {
		display: flex;
		gap: 1.25rem;
		font-size: 0.8rem;
		color: var(--muted-foreground);
	}
	.fc-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		background: none;
		border: none;
		border-radius: var(--radius-md);
		color: var(--muted-foreground);
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.fc-close:hover {
		background: oklch(from var(--foreground) l c h / 8%);
		color: var(--foreground);
	}
	.fc-card {
		perspective: 1200px;
		cursor: pointer;
	}
	.fc-card-inner {
		display: grid;
		min-height: 9rem;
		transform-style: preserve-3d;
		transition: transform 0.4s ease;
	}
	.fc-card-inner.is-flipped {
		transform: rotateX(180deg);
	}
	.fc-face {
		grid-area: 1 / 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		border-radius: var(--radius-xl);
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
	}
	.fc-card-front {
		background: var(--card);
	}
	.fc-card-back {
		transform: rotateX(180deg);
		background: oklch(from var(--accent-alt) l c h / 0.06);
		border-color: oklch(from var(--accent-alt) l c h / 0.25);
	}
	.fc-card-mastered .fc-card-front {
		border-color: oklch(from var(--accent-alt) l c h / 0.4);
		background: oklch(from var(--accent-alt) l c h / 0.04);
	}
	.fc-face-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.5rem;
	}
	.fc-face-tag {
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	.fc-card-front .fc-face-tag { color: var(--accent); }
	.fc-card-back .fc-face-tag { color: var(--accent-alt-dark); }
	.fc-post-title {
		font-size: 0.65rem;
		color: var(--muted-foreground);
		opacity: 0.7;
	}
	.fc-face-text {
		flex: 1;
		font-size: 1.05rem;
		line-height: 1.5;
		color: var(--foreground);
	}
	.fc-face-hint {
		margin-top: 0.75rem;
		font-size: 0.7rem;
		color: var(--muted-foreground);
		text-align: right;
		opacity: 0.5;
	}
	.fc-actions {
		display: flex;
		gap: 0.75rem;
	}
	.fc-btn {
		flex: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		padding: 0.6em 1em;
		border-radius: var(--radius-xl);
		font-family: inherit;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s, color 0.15s;
	}
	.fc-btn-again {
		background: color-mix(in oklch, var(--input) 30%, transparent);
		border: 1px solid oklch(from var(--foreground) l c h / 12%);
		color: var(--foreground);
	}
	.fc-btn-again:hover { background: color-mix(in oklch, var(--input) 55%, transparent); }
	.fc-btn-got-it {
		background: oklch(from var(--accent-alt) l c h / 0.12);
		border: 1px solid oklch(from var(--accent-alt) l c h / 0.3);
		color: var(--accent-alt-dark);
	}
	.fc-btn-got-it:hover { background: oklch(from var(--accent-alt) l c h / 0.22); }
	.fc-summary {
		padding: 0.5rem 0 0.75rem;
		text-align: center;
	}
	.fc-summary-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--foreground);
		margin: 0 0 0.25rem;
	}
	.fc-summary-score {
		color: var(--muted-foreground);
		font-size: 0.875rem;
		margin: 0 0 1.25rem;
	}
	.fc-summary-btns {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
	}
	.fc-summary-btns .fc-btn {
		flex: 0 0 auto;
		padding: 0.6em 1.5em;
	}

	@media (prefers-color-scheme: dark) {
		h2 a,
		h2 a.active {
			color: rgb(var(--gray-light));
		}
		#search-btn {
			color: rgb(var(--gray-light));
			opacity: 0.6;
		}
		#search-btn:hover {
			color: var(--accent);
			opacity: 1;
		}
		#shortcuts-btn,
		#sidebar-toggle {
			border-color: oklch(1 0 0 / 10%);
			color: rgb(var(--gray-light));
			box-shadow: 0 1px 4px rgba(0, 0, 0, 30%);
		}
		aside {
			border-right-color: oklch(1 0 0 / 10%);
			box-shadow: 2px 0 8px rgba(0, 0, 0, 30%);
		}
		.nav-links :global(a) {
			color: rgb(var(--gray-light));
		}
		.nav-links :global(a.heading-link) {
			color: rgb(var(--gray-light));
			opacity: 0.6;
		}
		.nav-links :global(a.heading-link:hover) {
			opacity: 1;
			color: var(--accent-alt-light);
		}
		.nav-links :global(a.heading-link.active-section) {
			color: var(--accent-alt-light);
			border-left-color: var(--accent-alt-light);
		}
		.nav-links :global(a.heading-link[data-visited]:not(.active-section)) {
			opacity: 0.35;
		}
		:global(.fc-review-dialog) {
			box-shadow: 0 16px 64px oklch(0 0 0 / 50%);
		}
		:global(.fc-review-dialog::backdrop) {
			background: oklch(0 0 0 / 65%);
		}
		.fc-card-back .fc-face-tag { color: var(--accent-alt-light); }
		.fc-card-back { background: oklch(from var(--accent-alt) l c h / 0.1); }
		.fc-btn-got-it { color: var(--accent-alt-light); }
		.fc-review-btn { color: rgb(var(--gray-light)); opacity: 0.6; }
		.fc-review-btn:hover { color: var(--accent); opacity: 1; }
	}
</style>

<script>
	// All setup runs on every astro:page-load so references are always to the current DOM.
	// AbortController cleans up per-page listeners before each swap.
	let abort = new AbortController();

	document.addEventListener('astro:before-swap', () => {
		document.body.style.overflow = '';
		abort.abort();
		abort = new AbortController();
	});

	document.addEventListener('astro:page-load', () => {
		const toggle = document.getElementById('sidebar-toggle');
		const sidebar = document.getElementById('sidebar');
		if (!toggle || !sidebar) return;

		const nav = sidebar.querySelector('nav');
		const thumb = document.getElementById('nav-scrollbar-thumb');
		const { signal } = abort;

		// Nav scrollbar thumb
		let scrollTimer: ReturnType<typeof setTimeout>;
		function updateThumb() {
			if (!nav || !thumb) return;
			const ratio = nav.clientHeight / nav.scrollHeight;
			thumb.style.height = `${nav.clientHeight * ratio}px`;
			thumb.style.top = `${(nav.scrollTop / nav.scrollHeight) * nav.clientHeight}px`;
		}
		nav?.addEventListener('scroll', () => {
			updateThumb();
			thumb?.classList.add('visible');
			clearTimeout(scrollTimer);
			scrollTimer = setTimeout(() => thumb?.classList.remove('visible'), 800);
		}, { passive: true, signal });
		updateThumb();

		// Collapse / expand
		function setCollapsed(collapsed: boolean, instant = false, save = true) {
			if (instant) {
				sidebar!.style.transition = 'none';
				document.body.style.transition = 'none';
			}
			sidebar!.classList.toggle('collapsed', collapsed);
			document.body.classList.toggle('sidebar-collapsed', collapsed);
			toggle!.setAttribute('aria-expanded', String(!collapsed));
			if (save) localStorage.setItem('sidebar-collapsed', String(collapsed));
			if (instant) {
				requestAnimationFrame(() => requestAnimationFrame(() => {
					sidebar!.style.transition = '';
					document.body.style.transition = '';
				}));
			}
		}

		toggle.addEventListener('click', () => {
			setCollapsed(!sidebar.classList.contains('collapsed'));
		}, { signal });

		// Keyboard shortcut dispatch from BlogPost.astro
		document.addEventListener('sidebar-set-collapsed', ((e: CustomEvent) => {
			setCollapsed(e.detail.collapsed);
		}) as EventListener, { signal });

		document.getElementById('search-btn')?.addEventListener('click', () => {
			document.dispatchEvent(new CustomEvent('open-search'));
		}, { signal });

		document.getElementById('shortcuts-btn')?.addEventListener('click', () => {
			document.dispatchEvent(new CustomEvent('open-shortcuts'));
		}, { signal });

		// ── Global flashcard review ──────────────────────────────────────────
		const fcData = document.getElementById('fc-data')
		const reviewBtn = document.getElementById('fc-review-btn') as HTMLButtonElement | null
		const reviewDialog = document.getElementById('fc-review-dialog') as HTMLDialogElement | null

		if (fcData && reviewBtn && reviewDialog) {
			type Card = { id: string; postTitle: string; front: string; back: string }
			const allCards: Card[] = JSON.parse(fcData.dataset.cards ?? '[]')

			function shuffle(arr: Card[]): Card[] {
				const a = [...arr]
				for (let i = a.length - 1; i > 0; i--) {
					const j = Math.floor(Math.random() * (i + 1))
					;[a[i], a[j]] = [a[j], a[i]]
				}
				return a
			}

			const storageKey = 'learning-flashcards-global'
			const getMastered = () =>
				new Set<string>(JSON.parse(localStorage.getItem(storageKey) ?? '[]') as string[])
			const saveMastered = (m: Set<string>) =>
				localStorage.setItem(storageKey, JSON.stringify([...m]))

			const progressEl = document.getElementById('fc-progress')
			const masteryEl  = document.getElementById('fc-mastery')
			const cardEl     = document.getElementById('fc-card')
			const cardInner  = document.getElementById('fc-card-inner')
			const postTitleEl= document.getElementById('fc-post-title')
			const frontText  = document.getElementById('fc-front-text')
			const backText   = document.getElementById('fc-back-text')
			const actionsEl  = document.getElementById('fc-actions')
			const againBtn   = document.getElementById('fc-again')   as HTMLButtonElement | null
			const gotItBtn   = document.getElementById('fc-got-it')  as HTMLButtonElement | null
			const summaryEl  = document.getElementById('fc-summary')
			const summaryScore = document.getElementById('fc-summary-score')
			const restartBtn = document.getElementById('fc-restart') as HTMLButtonElement | null
			const doneBtn    = document.getElementById('fc-done')    as HTMLButtonElement | null
			const closeBtn   = document.getElementById('fc-close')   as HTMLButtonElement | null

			let queue: Card[] = []
			let queuePos = 0
			let mastered = new Set<string>()
			let isFlipped = false

			function updateMeta() {
				if (progressEl) progressEl.textContent = `${queuePos + 1} / ${queue.length}`
				if (masteryEl)  masteryEl.textContent  = `${mastered.size} mastered`
			}

			function showCard(pos: number) {
				const card = queue[pos]
				isFlipped = false
				cardInner?.classList.remove('is-flipped')
				if (frontText)   frontText.textContent   = card.front
				if (backText)    backText.textContent    = card.back
				if (postTitleEl) postTitleEl.textContent = card.postTitle
				if (actionsEl)   actionsEl.hidden        = true
				cardEl?.classList.toggle('fc-card-mastered', mastered.has(card.id))
				updateMeta()
			}

			function flip() {
				if (isFlipped) return
				isFlipped = true
				cardInner?.classList.add('is-flipped')
				if (actionsEl) actionsEl.hidden = false
				setTimeout(() => gotItBtn?.focus(), 50)
			}

			function advance() {
				queuePos++
				if (queuePos >= queue.length) showSummary()
				else showCard(queuePos)
			}

			function showSummary() {
				if (cardEl)    cardEl.hidden    = true
				if (actionsEl) actionsEl.hidden = true
				if (progressEl) progressEl.textContent = 'Done!'
				if (masteryEl)  masteryEl.textContent  = ''
				if (summaryEl)  summaryEl.hidden       = false
				if (summaryScore) summaryScore.textContent = `${mastered.size} of ${allCards.length} mastered`
				setTimeout(() => doneBtn?.focus(), 50)
			}

			function openReview() {
				mastered = getMastered()
				queue = shuffle(allCards)
				queuePos = 0
				if (cardEl)    cardEl.hidden    = false
				if (summaryEl) summaryEl.hidden = true
				reviewDialog.showModal()
				document.body.style.overflow = 'hidden'
				showCard(0)
			}

			function closeReview() {
				reviewDialog.close()
				document.body.style.overflow = ''
				reviewBtn.focus()
			}

			reviewBtn.addEventListener('click', openReview, { signal })
			closeBtn?.addEventListener('click', closeReview, { signal })
			cardEl?.addEventListener('click', () => flip(), { signal })

			againBtn?.addEventListener('click', () => {
				mastered.delete(queue[queuePos].id)
				saveMastered(mastered)
				advance()
			}, { signal })

			gotItBtn?.addEventListener('click', () => {
				mastered.add(queue[queuePos].id)
				saveMastered(mastered)
				advance()
			}, { signal })

			restartBtn?.addEventListener('click', openReview, { signal })
			doneBtn?.addEventListener('click', closeReview, { signal })

			reviewDialog.addEventListener('close', () => {
				document.body.style.overflow = ''
				reviewBtn.focus()
			}, { signal })

			document.addEventListener('keydown', (e) => {
				const active = document.activeElement as HTMLElement | null
				if (reviewDialog.open) {
					if ((e.key === ' ' || e.key === 'Enter') && active?.tagName !== 'BUTTON') {
						e.preventDefault()
						flip()
					}
					if (!actionsEl?.hidden) {
						if (e.key === 'g' || e.key === 'y') gotItBtn?.click()
						if (e.key === 'n') againBtn?.click()
					}
				} else {
					const inInput = active && ['INPUT', 'TEXTAREA', 'SELECT'].includes(active.tagName)
					if (e.key === 'r' && !inInput && !active?.isContentEditable && !document.querySelector('dialog[open]')) {
						openReview()
					}
				}
			}, { signal })
		}

		// Section tracking
		const headingLinks = document.querySelectorAll<HTMLAnchorElement>('.heading-link');
		if (headingLinks.length === 0) return;

		const headingEls = Array.from(headingLinks).map((link) => {
			const id = link.getAttribute('href')!.slice(1);
			return document.getElementById(id);
		}).filter((el): el is HTMLElement => el !== null);

		let activeEl: HTMLElement | null = null;
		let lastScrollY = window.scrollY;

		function setActive(el: HTMLElement | null) {
			if (el === activeEl) return;
			activeEl = el;
			headingLinks.forEach((link) => {
				const id = link.getAttribute('href')!.slice(1);
				link.classList.toggle('active-section', el?.id === id);
			});
		}

		function updateActiveHeading() {
			const midpoint = window.innerHeight * 0.4;
			const scrollingUp = window.scrollY < lastScrollY;
			lastScrollY = window.scrollY;
			let current: HTMLElement | null = null;
			for (const el of headingEls) {
				const top = el.getBoundingClientRect().top;
				if (scrollingUp) {
					// When scrolling up: once a heading has gone below the midpoint,
					// the previous heading (stored in current) should be active
					if (top > midpoint) break;
					current = el;
				} else {
					// When scrolling down: activate the last heading above the midpoint
					if (top <= midpoint) current = el;
				}
			}
			setActive(current ?? headingEls[0]);
			// Mark sections whose headings have scrolled above the viewport as visited.
			headingLinks.forEach((link) => {
				const id = link.getAttribute('href')!.slice(1);
				const el = document.getElementById(id);
				if (el && el.getBoundingClientRect().top < 0) link.dataset.visited = 'true';
			});
		}

		window.addEventListener('scroll', updateActiveHeading, { passive: true, signal });
		updateActiveHeading();
	});
</script>
