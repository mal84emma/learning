---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import FontSizeControl from './FontSizeControl.astro';

type Heading = { depth: number; slug: string; text: string };
interface Props { headings?: Heading[] }

const { headings = [] } = Astro.props;
const h1s = headings.filter((h) => h.depth === 1 || h.depth === 2);

const posts = (await getCollection('blog')).sort(
	(a, b) => (a.data.orderingNumber) - (b.data.orderingNumber),
);

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<aside id="sidebar" data-pagefind-ignore>
	<script is:inline>
		// Apply collapsed state synchronously before first paint to avoid flash
		const savedState = localStorage.getItem('sidebar-collapsed');
		if (savedState === 'true' || (savedState === null && window.innerWidth < 1000)) {
			document.getElementById('sidebar').classList.add('collapsed');
			document.body.classList.add('sidebar-collapsed');
		}
	</script>
	<div class="nav-scrollbar" id="nav-scrollbar">
		<div class="nav-scrollbar-thumb" id="nav-scrollbar-thumb"></div>
	</div>
	<button id="shortcuts-btn" aria-label="Keyboard shortcuts">?</button>
	<button id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="true">
		<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
			<line x1="3" y1="6" x2="21" y2="6" />
			<line x1="3" y1="12" x2="21" y2="12" />
			<line x1="3" y1="18" x2="21" y2="18" />
		</svg>
	</button>
	<nav>
		<div class="nav-header">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
			<button id="search-btn" aria-label="Search">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8" />
					<line x1="21" y1="21" x2="16.65" y2="16.65" />
				</svg>
			</button>
		</div>
		<div class="nav-links">
			{posts.map((post) => {
				const postHref = `${base}/blog/${post.id}`;
				const isActive = currentPath === postHref;
				return (
					<>
						<a href={postHref} class={isActive ? 'active' : ''}>
							{post.data.title}
						</a>
						{isActive && h1s.length > 0 && (
							<div class="headings">
								{h1s.map((h) => (
									<a href={`#${h.slug}`} class={`heading-link heading-h${h.depth}`}>
										{h.text}
									</a>
								))}
							</div>
						)}
					</>
				);
			})}
		</div>
		<FontSizeControl />
	</nav>
</aside>

<style>
	#shortcuts-btn {
		position: absolute;
		top: 4rem;
		right: 0.5rem;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		background: var(--background);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		color: rgb(var(--gray-dark));
		cursor: pointer;
		box-shadow: 0 1px 4px rgba(var(--black), 8%);
		font-size: 0.85rem;
		font-weight: 600;
		font-family: inherit;
		transition: color 0.2s ease;
	}
	#shortcuts-btn:hover {
		color: var(--accent);
	}
	#sidebar-toggle {
		position: absolute;
		top: 1rem;
		right: 0.5rem;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		background: var(--background);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		color: rgb(var(--gray-dark));
		cursor: pointer;
		box-shadow: 0 1px 4px rgba(var(--black), 8%);
		transition: color 0.2s ease;
	}
	#sidebar-toggle:hover {
		color: var(--accent);
	}
	aside {
		position: fixed;
		top: 0;
		left: 0;
		width: var(--sidebar-width);
		height: 100vh;
		background: var(--background);
		border-right: 1px solid rgb(var(--gray-light));
		box-shadow: 2px 0 8px rgba(var(--black), 5%);
		z-index: 100;
		transition:
			transform 1s ease,
			background-color 1.25s ease,
			border-color 1.25s ease,
			box-shadow 1.25s ease;
	}
	aside.collapsed {
		transform: translateX(calc(3.25rem - var(--sidebar-width)));
		background-color: transparent;
		border-color: transparent;
		box-shadow: none;
	}
	aside.collapsed nav {
		opacity: 0;
	}
	nav {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 4em 0 2em;
		overflow-y: auto;
		scrollbar-width: none;
		transition: opacity 0.5s ease;
		position: relative;
		z-index: 1;
	}
	nav::-webkit-scrollbar {
		display: none;
	}
	.nav-scrollbar {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 1px;
		pointer-events: none;
		z-index: 0;
	}
	.nav-scrollbar-thumb {
		position: absolute;
		left: 0;
		width: 5px;
		background: rgb(var(--gray-dark));
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.nav-scrollbar-thumb.visible {
		opacity: 1;
	}
	.nav-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-right: 0.75em;
		margin-bottom: 2em;
	}
	#search-btn {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		padding: 0;
		background: none;
		border: none;
		border-radius: var(--radius-sm);
		color: rgb(var(--gray));
		cursor: pointer;
		transition: color 0.2s ease;
	}
	#search-btn:hover {
		color: var(--accent);
	}
	aside.collapsed :global(#search-btn) {
		opacity: 0;
		pointer-events: none;
	}
	h2 {
		margin: 0;
		padding: 0 0 0 1.5em;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 700;
		font-size: 1.25em;
		transition: color 0.2s ease;
	}
	h2 a:hover,
	h2 a.active:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
	.nav-links :global(a) {
		display: block;
		padding: 0.75em 1.5em;
		color: rgb(var(--gray-dark));
		border-left: 4px solid transparent;
		border-bottom: none;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.nav-links :global(a.active) {
		border-left-color: var(--accent);
		color: var(--accent);
	}
	.nav-links :global(a:hover) {
		color: var(--accent);
	}
	.headings {
		display: flex;
		flex-direction: column;
	}
	.nav-links :global(a.heading-link) {
		padding: 0.25em 1.5em 0.25em 2.5em;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		transition: color 1.5s ease, border-left-color 1.5s ease;
	}
	.nav-links :global(a.heading-link:hover) {
		color: var(--accent-alt-dark) !important;
	}
	.nav-links :global(a.heading-h2) {
		padding-left: 3.5em;
	}
	.nav-links :global(a.heading-link.active-section) {
		color: var(--accent-alt-dark);
		opacity: 1;
		border-left-color: var(--accent-alt-dark);
	}
	aside.collapsed :global(.font-size-control) {
		opacity: 0;
		pointer-events: none;
	}
	.social-links {
		display: flex;
		flex-direction: row;
		gap: 0.75em;
		margin-top: auto;
		padding: 0 1.5em;
	}
	.social-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (prefers-color-scheme: dark) {
		h2 a,
		h2 a.active {
			color: rgb(var(--gray-light));
		}
		#shortcuts-btn {
			border-color: oklch(1 0 0 / 10%);
			color: rgb(var(--gray-light));
			box-shadow: 0 1px 4px rgba(0, 0, 0, 30%);
		}
		#search-btn {
			color: rgb(var(--gray-light));
			opacity: 0.6;
		}
		#search-btn:hover {
			color: var(--accent);
			opacity: 1;
		}
		#sidebar-toggle {
			border-color: oklch(1 0 0 / 10%);
			color: rgb(var(--gray-light));
			box-shadow: 0 1px 4px rgba(0, 0, 0, 30%);
		}
		aside {
			border-right-color: oklch(1 0 0 / 10%);
			box-shadow: 2px 0 8px rgba(0, 0, 0, 30%);
		}
		.nav-links :global(a) {
			color: rgb(var(--gray-light));
		}
		.nav-links :global(a.heading-link) {
			color: rgb(var(--gray-light));
			opacity: 0.6;
		}
		.nav-links :global(a.heading-link:hover) {
			opacity: 1;
			color: var(--accent-alt-light);
		}
		.nav-links :global(a.heading-link.active-section) {
			color: var(--accent-alt-light);
			border-left-color: var(--accent-alt-light);
		}
	}
</style>

<script>
	const toggle = document.getElementById('sidebar-toggle')!;
	const sidebar = document.getElementById('sidebar')!;
	const nav = sidebar.querySelector('nav')!;
	const thumb = document.getElementById('nav-scrollbar-thumb')!;

	let scrollTimer: ReturnType<typeof setTimeout>;

	function updateThumb() {
		const ratio = nav.clientHeight / nav.scrollHeight;
		const thumbHeight = nav.clientHeight * ratio;
		const thumbTop = (nav.scrollTop / nav.scrollHeight) * nav.clientHeight;
		thumb.style.height = `${thumbHeight}px`;
		thumb.style.top = `${thumbTop}px`;
	}

	nav.addEventListener('scroll', () => {
		updateThumb();
		thumb.classList.add('visible');
		clearTimeout(scrollTimer);
		scrollTimer = setTimeout(() => thumb.classList.remove('visible'), 800);
	}, { passive: true });

	updateThumb();

	function setCollapsed(collapsed: boolean, instant = false, save = true) {
		if (instant) {
			sidebar.style.transition = 'none';
			document.body.style.transition = 'none';
		}
		sidebar.classList.toggle('collapsed', collapsed);
		document.body.classList.toggle('sidebar-collapsed', collapsed);
		toggle.setAttribute('aria-expanded', String(!collapsed));
		if (save) localStorage.setItem('sidebar-collapsed', String(collapsed));
		if (instant) {
			// Re-enable transitions after the instantaneous state change has been painted
			requestAnimationFrame(() => requestAnimationFrame(() => {
				sidebar.style.transition = '';
				document.body.style.transition = '';
			}));
		}
	}

	const savedState = localStorage.getItem('sidebar-collapsed');
	if (savedState === 'true') {
		// Restore explicitly persisted collapsed state without animation
		setCollapsed(true, true);
	} else if (savedState === null && window.innerWidth < 1000) {
		// No saved preference: default to closed on viewports narrower than content max-width
		// Don't persist this so the toggle always reflects the user's explicit choice
		setCollapsed(true, true, false);
	}

	toggle.addEventListener('click', () => {
		setCollapsed(!sidebar.classList.contains('collapsed'));
	});

	document.addEventListener('sidebar-set-collapsed', ((e: CustomEvent) => {
		setCollapsed(e.detail.collapsed);
	}) as EventListener);

	document.getElementById('search-btn')?.addEventListener('click', () => {
		document.dispatchEvent(new CustomEvent('open-search'));
	});

	document.getElementById('shortcuts-btn')?.addEventListener('click', () => {
		document.dispatchEvent(new CustomEvent('open-shortcuts'));
	});

	// Highlight active section heading based on scroll position
	const headingLinks = document.querySelectorAll<HTMLAnchorElement>('.heading-link');
	if (headingLinks.length > 0) {
		const headingEls = Array.from(headingLinks).map((link) => {
			const id = link.getAttribute('href')!.slice(1);
			return document.getElementById(id);
		}).filter((el): el is HTMLElement => el !== null);

		let activeEl: HTMLElement | null = null;
		let lastScrollY = window.scrollY;

		function setActive(el: HTMLElement | null) {
			if (el === activeEl) return;
			activeEl = el;
			headingLinks.forEach((link) => {
				const id = link.getAttribute('href')!.slice(1);
				link.classList.toggle('active-section', el?.id === id);
			});
		}

		function updateActiveHeading() {
			const midpoint = window.innerHeight * 0.4;
			const scrollingUp = window.scrollY < lastScrollY;
			lastScrollY = window.scrollY;

			let current: HTMLElement | null = null;

			for (const el of headingEls) {
				const top = el.getBoundingClientRect().top;
				if (scrollingUp) {
					// When scrolling up: once a heading has gone below the midpoint,
					// the previous heading (stored in current) should be active
					if (top > midpoint) break;
					current = el;
				} else {
					// When scrolling down: activate the last heading above the midpoint
					if (top <= midpoint) current = el;
				}
			}

			setActive(current ?? headingEls[0]);
		}

		window.addEventListener('scroll', updateActiveHeading, { passive: true });
		updateActiveHeading();
	}
</script>
