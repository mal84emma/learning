---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

type Heading = { depth: number; slug: string; text: string };
interface Props { headings?: Heading[] }

const { headings = [] } = Astro.props;
const h1s = headings.filter((h) => h.depth === 1 || h.depth === 2);

const posts = (await getCollection('blog')).sort(
	(a, b) => (a.data.orderingNumber) - (b.data.orderingNumber),
);

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<aside id="sidebar">
	<button id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="true">
		<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
			<line x1="3" y1="6" x2="21" y2="6" />
			<line x1="3" y1="12" x2="21" y2="12" />
			<line x1="3" y1="18" x2="21" y2="18" />
		</svg>
	</button>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		<div class="nav-links">
			{posts.map((post) => {
				const postHref = `${base}/blog/${post.id}`;
				const isActive = currentPath === postHref;
				return (
					<>
						<a href={postHref} class={isActive ? 'active' : ''}>
							{post.data.title}
						</a>
						{isActive && h1s.length > 0 && (
							<div class="headings">
								{h1s.map((h) => (
									<a href={`#${h.slug}`} class={`heading-link heading-h${h.depth}`}>
										{h.text}
									</a>
								))}
							</div>
						)}
					</>
				);
			})}
		</div>
		<div class="social-links">
			<a href="https://m.webtoo.ls/@astro" target="_blank">
				<span class="sr-only">Follow Astro on Mastodon</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
					></path></svg
				>
			</a>
			<a href="https://twitter.com/astrodotbuild" target="_blank">
				<span class="sr-only">Follow Astro on Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/withastro/astro" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</aside>

<style>
	#sidebar-toggle {
		position: absolute;
		top: 1rem;
		right: 0.5rem;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		background: var(--background);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-md);
		color: rgb(var(--gray-dark));
		cursor: pointer;
		box-shadow: 0 1px 4px rgba(var(--black), 8%);
		transition: color 0.2s ease;
	}
	#sidebar-toggle:hover {
		color: var(--accent);
	}
	aside {
		position: fixed;
		top: 0;
		left: 0;
		width: var(--sidebar-width);
		height: 100vh;
		background: var(--background);
		border-right: 1px solid rgb(var(--gray-light));
		box-shadow: 2px 0 8px rgba(var(--black), 5%);
		z-index: 100;
		transition:
			transform 0.5s ease,
			background-color 0.5s ease,
			border-color 0.5s ease,
			box-shadow 0.5s ease;
	}
	aside.collapsed {
		transform: translateX(calc(3.25rem - var(--sidebar-width)));
		background-color: transparent;
		border-color: transparent;
		box-shadow: none;
	}
	aside.collapsed nav {
		opacity: 0;
	}
	nav {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 4em 0 2em;
		transition: opacity 0.5s ease;
	}
	h2 {
		margin: 0 0 2em 0;
		padding: 0 1.5em;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--accent-alt);
		font-weight: 700;
		font-size: 1.25em;
		transition: color 0.2s ease;
	}
	h2 a:hover,
	h2 a.active:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
	.nav-links :global(a) {
		display: block;
		padding: 0.75em 1.5em;
		color: rgb(var(--gray-dark));
		border-left: 4px solid transparent;
		border-bottom: none;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.nav-links :global(a.active) {
		border-left-color: var(--accent);
		color: var(--accent);
	}
	.nav-links :global(a:hover) {
		color: var(--accent);
	}
	.headings {
		display: flex;
		flex-direction: column;
	}
	.nav-links :global(a.heading-link) {
		padding: 0.25em 1.5em 0.25em 2.5em;
		font-size: 0.85em;
		color: rgb(var(--gray));
		transition: color 1.5s ease, border-left-color 1.5s ease;
	}
	.nav-links :global(a.heading-link:hover) {
		color: var(--accent-alt) !important;
	}
	.nav-links :global(a.heading-h2) {
		padding-left: 3.5em;
	}
	.nav-links :global(a.heading-link.active-section) {
		color: var(--accent-alt);
		opacity: 1;
		border-left-color: var(--accent-alt);
	}
	.social-links {
		display: flex;
		flex-direction: row;
		gap: 0.75em;
		margin-top: auto;
		padding: 0 1.5em;
	}
	.social-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (prefers-color-scheme: dark) {
		.nav-links :global(a.heading-link) {
			color: rgb(var(--gray-light));
			opacity: 0.6;
		}
		.nav-links :global(a.heading-link:hover) {
			opacity: 1;
			color: var(--accent);
		}
	}
	@media (prefers-color-scheme: dark) {
		#sidebar-toggle {
			border-color: oklch(1 0 0 / 10%);
			color: rgb(var(--gray-light));
			box-shadow: 0 1px 4px rgba(0, 0, 0, 30%);
		}
		aside {
			border-right-color: oklch(1 0 0 / 10%);
			box-shadow: 2px 0 8px rgba(0, 0, 0, 30%);
		}
		.nav-links :global(a) {
			color: rgb(var(--gray-light));
		}
	}
</style>

<script>
	const toggle = document.getElementById('sidebar-toggle')!;
	const sidebar = document.getElementById('sidebar')!;

	function setCollapsed(collapsed: boolean) {
		sidebar.classList.toggle('collapsed', collapsed);
		document.body.classList.toggle('sidebar-collapsed', collapsed);
		toggle.setAttribute('aria-expanded', String(!collapsed));
		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	// Restore persisted state before first paint
	if (localStorage.getItem('sidebar-collapsed') === 'true') {
		setCollapsed(true);
	}

	toggle.addEventListener('click', () => {
		setCollapsed(!sidebar.classList.contains('collapsed'));
	});

	// Highlight active section heading based on scroll position
	const headingLinks = document.querySelectorAll<HTMLAnchorElement>('.heading-link');
	if (headingLinks.length > 0) {
		const headingEls = Array.from(headingLinks).map((link) => {
			const id = link.getAttribute('href')!.slice(1);
			return document.getElementById(id);
		}).filter((el): el is HTMLElement => el !== null);

		let activeEl: HTMLElement | null = null;
		let lastScrollY = window.scrollY;

		function setActive(el: HTMLElement | null) {
			if (el === activeEl) return;
			activeEl = el;
			headingLinks.forEach((link) => {
				const id = link.getAttribute('href')!.slice(1);
				link.classList.toggle('active-section', el?.id === id);
			});
		}

		function updateActiveHeading() {
			const midpoint = window.innerHeight * 0.4;
			const scrollingUp = window.scrollY < lastScrollY;
			lastScrollY = window.scrollY;

			let current: HTMLElement | null = null;

			for (const el of headingEls) {
				const top = el.getBoundingClientRect().top;
				if (scrollingUp) {
					// When scrolling up: once a heading has gone below the midpoint,
					// the previous heading (stored in current) should be active
					if (top > midpoint) break;
					current = el;
				} else {
					// When scrolling down: activate the last heading above the midpoint
					if (top <= midpoint) current = el;
				}
			}

			setActive(current ?? headingEls[0]);
		}

		window.addEventListener('scroll', updateActiveHeading, { passive: true });
		updateActiveHeading();
	}
</script>
